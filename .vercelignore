# Never upload these — rebuilt or served separately on Vercel
/node_modules
/vendor

# Local uploads (not needed in deploy)
/storage/app
/storage/logs
/storage/framework/cache
/storage/framework/sessions
/storage/framework/views
/storage/pail
/storage/*.key
/public/storage

# Build-time artifacts (generated by scripts/vercel-prepare.sh)
api/php-fpm-bin
api/laravel

# Dev / test
/tests
.phpunit.cache
.phpunit.result.cache
.env
.env.*
!.env.example
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
.idea
.vscode
.fleet
.nova
.zed
.phpactor.json
/auth.json
/public/hot
